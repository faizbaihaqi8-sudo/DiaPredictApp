<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DiaPredictApp.Pages.FaceVerificationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4FFFC">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryTeal">#0A7C7C</Color>
            <Color x:Key="DarkTeal">#045D63</Color>
            <Color x:Key="TextSoft">#6F8B8F</Color>
            <Color x:Key="TextDark">#173B3F</Color>
            <Color x:Key="SuccessGreen">#159A6B</Color>
            <Color x:Key="DangerRed">#FF6B6B</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="30">

        <Border
            WidthRequest="980"
            MinimumHeightRequest="620"
            Background="White"
            Stroke="#DDEDEA"
            StrokeThickness="1"
            HorizontalOptions="Center"
            VerticalOptions="Center">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="0.95*,1.05*">

                <Grid
                    Grid.Column="0"
                    BackgroundColor="#0A7C7C"
                    Padding="38">

                    <VerticalStackLayout Spacing="18" VerticalOptions="Center">

                        <Border
                            WidthRequest="120"
                            HeightRequest="120"
                            Background="#DFF8F1"
                            StrokeThickness="0"
                            HorizontalOptions="Center">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="60" />
                            </Border.StrokeShape>

                            <Label
                                Text="ID"
                                FontSize="42"
                                FontAttributes="Bold"
                                TextColor="#0A7C7C"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <Label
                            Text="Verifikasi Wajah"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="White"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Ambil atau pilih foto wajah untuk proses verifikasi sebelum masuk ke dashboard."
                            FontSize="15"
                            TextColor="#EFFFFB"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="WordWrap" />

                        <Border
                            Padding="18"
                            Background="#22FFFFFF"
                            StrokeThickness="0"
                            Margin="0,18,0,0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="10">
                                <Label Text="1. Login berhasil" TextColor="White" FontSize="14" />
                                <Label Text="2. Ambil foto verifikasi" TextColor="White" FontSize="14" />
                                <Label Text="3. Masuk dashboard sesuai role" TextColor="White" FontSize="14" />
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout
                    Grid.Column="1"
                    Padding="46,34"
                    Spacing="15"
                    VerticalOptions="Center">

                    <Label
                        Text="Face Verification"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="{StaticResource DarkTeal}" />

                    <Label
                        Text="Ambil foto wajah untuk verifikasi. Kalau ingin membatalkan proses, tekan tombol kembali ke login di bawah."
                        FontSize="14"
                        TextColor="{StaticResource TextSoft}"
                        LineBreakMode="WordWrap" />

                    <Border
                        HeightRequest="270"
                        Background="#F9FFFD"
                        Stroke="#D7EDEA"
                        StrokeThickness="1"
                        Padding="12"
                        Margin="0,8,0,0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24" />
                        </Border.StrokeShape>

                        <Grid>

                            <Image
                                x:Name="VerificationPreviewImage"
                                Aspect="AspectFit"
                                BackgroundColor="#F9FFFD" />

                            <VerticalStackLayout
                                x:Name="EmptyPreviewLayout"
                                Spacing="8"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">

                                <Label
                                    Text="Belum ada foto verifikasi"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextSoft}"
                                    HorizontalTextAlignment="Center" />

                                <Label
                                    Text="Ambil atau pilih foto wajah terlebih dahulu."
                                    FontSize="13"
                                    TextColor="{StaticResource TextSoft}"
                                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <Label
                                x:Name="VerificationStatusLabel"
                                Text="Status: verifikasi belum dimulai"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextSoft}"
                                HorizontalOptions="Center"
                                VerticalOptions="End" />

                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <Button
                            Grid.Column="0"
                            Text="AMBIL FOTO"
                            HeightRequest="48"
                            CornerRadius="16"
                            BackgroundColor="{StaticResource PrimaryTeal}"
                            TextColor="White"
                            FontAttributes="Bold"
                            Clicked="OnCaptureVerificationClicked" />

                        <Button
                            Grid.Column="1"
                            Text="PILIH FOTO"
                            HeightRequest="48"
                            CornerRadius="16"
                            BackgroundColor="#DFF8F1"
                            TextColor="{StaticResource PrimaryTeal}"
                            FontAttributes="Bold"
                            Clicked="OnPickVerificationClicked" />
                    </Grid>

                    <Button
                        x:Name="VerifyButton"
                        Text="VERIFIKASI WAJAH"
                        HeightRequest="50"
                        CornerRadius="18"
                        BackgroundColor="#B8C9C9"
                        TextColor="White"
                        FontAttributes="Bold"
                        IsEnabled="False"
                        Clicked="OnVerifyClicked" />

                    <Button
                        Text="SIMULASI GAGAL"
                        HeightRequest="48"
                        CornerRadius="18"
                        BackgroundColor="#FFE7E7"
                        TextColor="{StaticResource DangerRed}"
                        FontAttributes="Bold"
                        Clicked="OnFailedSimulationClicked" />

                    <Button
                        Text="KEMBALI KE LOGIN"
                        HeightRequest="48"
                        CornerRadius="18"
                        BackgroundColor="#F1F8F7"
                        TextColor="{StaticResource PrimaryTeal}"
                        FontAttributes="Bold"
                        Clicked="OnBackToLoginClicked" />

                </VerticalStackLayout>

            </Grid>
        </Border>
    </Grid>
</ContentPage>