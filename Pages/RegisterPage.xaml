<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DiaPredictApp.Pages.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4FFFC">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryTeal">#0A7C7C</Color>
            <Color x:Key="DarkTeal">#045D63</Color>
            <Color x:Key="TextDark">#173B3F</Color>
            <Color x:Key="TextSoft">#6F8B8F</Color>
            <Color x:Key="SuccessGreen">#159A6B</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid Padding="30">

            <Border
                WidthRequest="980"
                MinimumHeightRequest="600"
                Background="White"
                Stroke="#DDEDEA"
                StrokeThickness="1"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="0.95*,1.05*">

                    <!-- BAGIAN KIRI -->
                    <Grid
                        Grid.Column="0"
                        BackgroundColor="#0A7C7C"
                        Padding="38">

                        <VerticalStackLayout
                            Spacing="18"
                            VerticalOptions="Center">

                            <Border
                                WidthRequest="120"
                                HeightRequest="120"
                                Background="#DFF8F1"
                                StrokeThickness="0"
                                HorizontalOptions="Center">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="60" />
                                </Border.StrokeShape>

                                <Label
                                    Text="+"
                                    FontSize="64"
                                    FontAttributes="Bold"
                                    TextColor="#0A7C7C"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>

                            <Label
                                Text="Buat Akun Baru"
                                FontSize="30"
                                FontAttributes="Bold"
                                TextColor="White"
                                HorizontalTextAlignment="Center" />

                            <Label
                                Text="Daftarkan akun dan wajah pengguna agar proses verifikasi dapat dilakukan sebelum masuk ke dashboard."
                                FontSize="15"
                                TextColor="#EFFFFB"
                                HorizontalTextAlignment="Center"
                                LineBreakMode="WordWrap" />

                            <Border
                                Padding="18"
                                Background="#22FFFFFF"
                                StrokeThickness="0"
                                Margin="0,18,0,0">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22" />
                                </Border.StrokeShape>

                                <VerticalStackLayout Spacing="10">
                                    <Label Text="1. Isi data akun pengguna" TextColor="White" FontSize="14" />
                                    <Label Text="2. Pilih role Pasien atau Nakes" TextColor="White" FontSize="14" />
                                    <Label Text="3. Daftarkan wajah sebelum menekan DAFTAR" TextColor="White" FontSize="14" />
                                </VerticalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </Grid>

                    <!-- BAGIAN KANAN -->
                    <VerticalStackLayout
                        Grid.Column="1"
                        Padding="46,34"
                        Spacing="13"
                        VerticalOptions="Center">

                        <Label
                            Text="Registrasi Akun"
                            FontSize="32"
                            FontAttributes="Bold"
                            TextColor="{StaticResource DarkTeal}" />

                        <Label
                            Text="Lengkapi data berikut untuk membuat akun DiaPredict."
                            FontSize="14"
                            TextColor="{StaticResource TextSoft}"
                            Margin="0,0,0,8" />

                        <Label Text="Nama Lengkap" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />

                        <Border HeightRequest="46" Stroke="#D7EDEA" StrokeThickness="1" Background="#F9FFFD" Padding="14,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>

                            <Entry
                                x:Name="FullNameEntry"
                                Placeholder="Masukkan nama lengkap"
                                PlaceholderColor="#9BB3B6"
                                TextColor="{StaticResource TextDark}"
                                BackgroundColor="Transparent"
                                TextChanged="OnInputChanged" />
                        </Border>

                        <Label Text="Username" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />

                        <Border HeightRequest="46" Stroke="#D7EDEA" StrokeThickness="1" Background="#F9FFFD" Padding="14,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>

                            <Entry
                                x:Name="UsernameEntry"
                                Placeholder="Buat username"
                                PlaceholderColor="#9BB3B6"
                                TextColor="{StaticResource TextDark}"
                                BackgroundColor="Transparent"
                                TextChanged="OnInputChanged" />
                        </Border>

                        <Label Text="Password" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />

                        <Border HeightRequest="46" Stroke="#D7EDEA" StrokeThickness="1" Background="#F9FFFD" Padding="14,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>

                            <Entry
                                x:Name="PasswordEntry"
                                Placeholder="Buat password"
                                PlaceholderColor="#9BB3B6"
                                TextColor="{StaticResource TextDark}"
                                BackgroundColor="Transparent"
                                IsPassword="True"
                                TextChanged="OnInputChanged" />
                        </Border>

                        <Label Text="Konfirmasi Password" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />

                        <Border HeightRequest="46" Stroke="#D7EDEA" StrokeThickness="1" Background="#F9FFFD" Padding="14,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>

                            <Entry
                                x:Name="ConfirmPasswordEntry"
                                Placeholder="Ulangi password"
                                PlaceholderColor="#9BB3B6"
                                TextColor="{StaticResource TextDark}"
                                BackgroundColor="Transparent"
                                IsPassword="True"
                                TextChanged="OnInputChanged" />
                        </Border>

                        <Label Text="Role" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextDark}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button
                                x:Name="PasienRoleButton"
                                Grid.Column="0"
                                Text="Pasien"
                                HeightRequest="46"
                                CornerRadius="14"
                                BackgroundColor="#F9FFFD"
                                TextColor="#6F8B8F"
                                FontAttributes="Bold"
                                Clicked="OnPasienRoleClicked" />

                            <Button
                                x:Name="NakesRoleButton"
                                Grid.Column="1"
                                Text="Nakes"
                                HeightRequest="46"
                                CornerRadius="14"
                                BackgroundColor="#F9FFFD"
                                TextColor="#6F8B8F"
                                FontAttributes="Bold"
                                Clicked="OnNakesRoleClicked" />
                        </Grid>

                        <Grid
                            ColumnDefinitions="*,*"
                            ColumnSpacing="12"
                            Margin="0,10,0,0">

                            <Button
                                x:Name="FaceRegisterButton"
                                Grid.Column="0"
                                Text="DAFTARKAN WAJAH"
                                HeightRequest="48"
                                CornerRadius="16"
                                BackgroundColor="#DFF8F1"
                                TextColor="{StaticResource PrimaryTeal}"
                                FontAttributes="Bold"
                                Clicked="OnFaceRegisterClicked" />

                            <Button
                                x:Name="RegisterButton"
                                Grid.Column="1"
                                Text="DAFTAR"
                                HeightRequest="48"
                                CornerRadius="16"
                                BackgroundColor="#B8C9C9"
                                TextColor="White"
                                FontAttributes="Bold"
                                IsEnabled="False"
                                Clicked="OnRegisterClicked" />
                        </Grid>

                        <Label
                            x:Name="StatusLabel"
                            Text="Status: isi semua data dan daftarkan wajah terlebih dahulu."
                            FontSize="12"
                            TextColor="{StaticResource TextSoft}"
                            HorizontalTextAlignment="Center" />

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label
                                Text="Sudah punya akun?"
                                FontSize="13"
                                TextColor="{StaticResource TextSoft}" />

                            <Label
                                Text="Kembali ke login"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="{StaticResource PrimaryTeal}">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnBackToLoginTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                </Grid>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>